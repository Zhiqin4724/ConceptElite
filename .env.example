# Squarespace API credentials (https://developers.squarespace.com/)
# Create an OAuth application or API key in your Squarespace developer dashboard.
SQUARESPACE_ACCESS_TOKEN=your_access_token_here
SQUARESPACE_APPLICATION_ID=your_application_id_here

# Optional: override the Squarespace API base URL
SQUARESPACE_API_BASE=https://api.squarespace.com
